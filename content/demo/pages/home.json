{
  "slug": "",
  "title": "Widget Showcase",
  "seo": {
    "description": "A polished demo portfolio site showcasing every v1 widget and multi-page navigation.",
    "og_image": "assets/logo.png"
  },
  "widgets": [
    {
      "type": "cover_banner",
      "props": {
        "src": "assets/logo.png",
        "alt": "Portfolio Website Builder widget demo"
      }
    },
    {
      "type": "intro",
      "props": {
        "title": "Widget Showcase",
        "paragraphs": [
          "This bundle demonstrates every registered v1 widget type, layout containers, and cross-page header navigation. Hash links scroll sections on this page; the About link opens a second route.",
          "Rebuild with: go run . --site content/demo"
        ]
      }
    },
    {
      "type": "grid",
      "id": "layout-grid",
      "props": {
        "min_column_width": "280px",
        "children": [
          {
            "type": "intro",
            "props": {
              "title": "Layout: grid",
              "paragraphs": ["This intro sits inside a CSS grid layout widget."]
            }
          },
          {
            "type": "intro",
            "props": {
              "title": "Layout: grid (2)",
              "paragraphs": ["Sibling column in the same grid row."]
            }
          }
        ]
      }
    },
    {
      "type": "row",
      "id": "layout-row",
      "props": {
        "children": [
          {
            "type": "column",
            "props": {
              "children": [
                {
                  "type": "intro",
                  "props": {
                    "title": "Layout: row → column",
                    "paragraphs": ["Nested row and column containers wrap this intro."]
                  }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "type": "project_grid",
      "props": {
        "heading": "Project grid",
        "subheading": "Portfolio-style cards with tags, meta, and CTAs",
        "section_id": "portfolio",
        "min_card_column_width": "260px",
        "cards": [
          {
            "title": "Alpha Toolkit",
            "description": "A sample project card with object meta and an external CTA.",
            "tags": ["Go", "Static"],
            "image": "assets/pic1.png",
            "meta": { "year": "2025", "platform": "Web" },
            "cta": { "label": "View repo", "url": "https://github.com/example/alpha" }
          },
          {
            "title": "Beta Release",
            "description": "Second card linking to the About page via internal slug reference.",
            "tags": ["Demo"],
            "image": "assets/pic2.png",
            "meta": "Highlighted sample",
            "cta": { "label": "About this demo", "url": "about" }
          }
        ]
      }
    },
    {
      "type": "apps_showcase",
      "props": {
        "section_title": "Apps showcase",
        "apps": [
          {
            "image": "assets/aoc-icon.png",
            "header_image": "assets/aoc_logo.png",
            "swiper_images": ["assets/aoc_c_1.jpg", "assets/aoc_c_2.jpeg"],
            "card_background": "linear-gradient(to bottom, #e7bdff 0, #d9ebfa 70%)",
            "title": "Sample App",
            "text_1": "Compact catalog card with store badges and screenshot carousel.",
            "text_2": "Subscribe block appears when site.json defines subscribe links.",
            "stat_left_line_1": "10k+",
            "stat_left_line_2": "Downloads",
            "stat_right_line_1": "4.5",
            "stat_right_line_2": "rating",
            "google_play_url": "https://play.google.com/store/apps/details?id=example.demo",
            "app_store_url": "https://apps.apple.com/app/example-demo/id0000000000"
          }
        ]
      }
    },
    {
      "type": "info_grid",
      "props": {
        "title": "Info grid",
        "items": [
          {
            "image": "assets/emoji_joy.png",
            "title": "Feature one",
            "text": "Small cards in a responsive info grid."
          },
          {
            "image": "assets/emoji_Medal.png",
            "title": "Feature two",
            "text": "Useful for perks, values, or highlights."
          }
        ]
      }
    },
    {
      "type": "images_grid",
      "props": {
        "title": "Images grid",
        "images": [
          { "src": "assets/pic1.png", "alt": "Demo photo one" },
          { "src": "assets/pic2.png", "alt": "Demo photo two" },
          { "src": "assets/pic3.png", "alt": "Demo photo three" }
        ]
      }
    },
    {
      "type": "media_swiper",
      "props": {
        "aria_label": "Demo media carousel",
        "images": [
          { "src": "assets/pic2.png", "alt": "Carousel slide one" },
          { "src": "assets/pic3.png", "alt": "Carousel slide two" }
        ]
      }
    },
    {
      "type": "careers_tabs",
      "props": {
        "title": "Careers tabs",
        "vacancies": [
          {
            "role": "Designer",
            "requirements": ["Portfolio", "Figma"],
            "responsibilities": ["UI for demo pages"],
            "advantages": ["Remote"],
            "apply_url": "mailto:demo@example.com",
            "apply_label": "Apply"
          },
          {
            "role": "Engineer",
            "requirements": ["Go experience"],
            "responsibilities": ["Generator features"],
            "advantages": ["Open source"],
            "apply_url": "mailto:demo@example.com?subject=Engineer",
            "apply_label": "Apply"
          }
        ]
      }
    },
    {
      "type": "follow_us",
      "props": {
        "title": "Follow us"
      }
    }
  ]
}
